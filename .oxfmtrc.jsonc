{
  "printWidth": 100,
  "useTabs": false,
  "tabWidth": 2,
  // CHANGELOG.md is generated by release-please and follows its formatting
  "ignorePatterns": [
    ".pnpm-store/**",
    ".idea/**",
    "out/**",
    "node_modules/**",
    "**/*.ctx.md",
    "CHANGELOG.md"
  ],
  "trailingComma": "none"
}
