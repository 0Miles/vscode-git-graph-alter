{
  "name": "vscode-git-graph-alter",
  "displayName": "%displayName%",
  "version": "0.4.0",
  "description": "%description%",
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "keywords": [
    "branch",
    "git",
    "git graph",
    "git history",
    "git log"
  ],
  "homepage": "https://github.com/your-org/vscode-git-graph-alter",
  "bugs": {
    "url": "https://github.com/your-org/vscode-git-graph-alter/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Miles",
    "email": "miles.huang@staff.nueip.com"
  },
  "contributors": [
    {
      "name": "Michael Hutchison",
      "url": "https://github.com/mhutchie"
    },
    {
      "name": "Asis Pattisahusiwa",
      "url": "https://github.com/asispts"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vscode-git-graph-alter.git"
  },
  "publisher": "your-publisher",
  "main": "./out/extension.js",
  "scripts": {
    "typecheck": "tsc -p ./src --noEmit && tsc -p ./src/webview --noEmit && tsc -p ./tests --noEmit",
    "vscode:prepublish": "pnpm run clean && pnpm run package",
    "package": "pnpm run typecheck && pnpm run lint && node esbuild.js --production",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "pnpm run clean && node esbuild.js",
    "test": "vitest run --project backend && vitest run --project webview",
    "test:ext": "pnpm run compile && pnpm run compile-tests && vscode-test",
    "compile-tests": "tsc -p tests/extension/tsconfig.json && tsc-alias -p tests/extension/tsconfig.json",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc -p ./src --noEmit --watch",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "l10n:check": "node ./scripts/check-l10n.js"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "~1.98.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.view",
        "title": "%command.view%",
        "icon": {
          "light": "resources/webview-icon-light.svg",
          "dark": "resources/webview-icon-dark.svg"
        }
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.clearAvatarCache",
        "title": "%command.clearAvatarCache%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.fetch",
        "title": "%command.fetch%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.manageRemotes",
        "title": "%command.manageRemotes%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.viewReflog",
        "title": "%command.viewReflog%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.showStatistics",
        "title": "%command.showStatistics%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.setRepoName",
        "title": "%command.setRepoName%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.exportRepoConfig",
        "title": "%command.exportRepoConfig%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.toggleRemoteVisibility",
        "title": "%command.toggleRemoteVisibility%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.fetchRemote",
        "title": "%command.fetchRemote%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.setGitUserDetails",
        "title": "%command.setGitUserDetails%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.openExtensionSettings",
        "title": "%command.openExtensionSettings%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.getVersionInfo",
        "title": "%command.getVersionInfo%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.openFileFromDiff",
        "title": "%command.openFileFromDiff%",
        "icon": "$(go-to-file)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.search",
        "title": "%command.branches.search%",
        "icon": "$(search)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.collapseAll",
        "title": "%command.branches.collapseAll%",
        "icon": "$(collapse-all)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.showAll",
        "title": "%command.branches.showAll%",
        "icon": "$(checklist)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.refresh",
        "title": "%command.branches.refresh%",
        "icon": "$(refresh)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.showRemoteBranches",
        "title": "%command.branches.showRemoteBranches%",
        "icon": {
          "light": "resources/icons/cloud-slash-light.svg",
          "dark": "resources/icons/cloud-slash-dark.svg"
        }
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.hideRemoteBranches",
        "title": "%command.branches.hideRemoteBranches%",
        "icon": {
          "light": "resources/icons/cloud-light.svg",
          "dark": "resources/icons/cloud-dark.svg"
        }
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.showInactive",
        "title": "%command.branches.showInactive%",
        "icon": "$(history)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.hideInactive",
        "title": "%command.branches.hideInactive%",
        "icon": "$(history)"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.checkout",
        "title": "%command.branches.checkout%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.merge",
        "title": "%command.branches.merge%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.rename",
        "title": "%command.branches.rename%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.delete",
        "title": "%command.branches.delete%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.copyName",
        "title": "%command.branches.copyName%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.rebase",
        "title": "%command.branches.rebase%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.fastForward",
        "title": "%command.branches.fastForward%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.push",
        "title": "%command.branches.push%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.createArchive",
        "title": "%command.branches.createArchive%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.createPullRequest",
        "title": "%command.branches.createPullRequest%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.pull",
        "title": "%command.branches.pull%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.fetchIntoLocal",
        "title": "%command.branches.fetchIntoLocal%"
      },
      {
        "category": "Git Graph Alter",
        "command": "git-graph-alter.branches.deleteRemote",
        "title": "%command.branches.deleteRemote%"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "git-graph-alter.branches",
          "name": "%view.branches%",
          "contextualTitle": "%view.branches%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "git-graph-alter.branches",
        "contents": "%view.branches.welcome%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "git-graph-alter.openFileFromDiff",
          "when": "resourceScheme == git-graph-alter",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "git-graph-alter.view",
          "group": "navigation",
          "when": "scmProvider == git && config.git-graph-alter.scmButtonPosition == 'Inline'"
        },
        {
          "command": "git-graph-alter.view",
          "when": "scmProvider == git && config.git-graph-alter.scmButtonPosition == 'More actions...'"
        }
      ],
      "scm/sourceControl": [
        {
          "command": "git-graph-alter.view",
          "when": "scmProvider == git",
          "group": "git-graph-alter@1"
        }
      ],
      "view/title": [
        {
          "command": "git-graph-alter.branches.showAll",
          "when": "view == git-graph-alter.branches",
          "group": "navigation@0"
        },
        {
          "command": "git-graph-alter.branches.refresh",
          "when": "view == git-graph-alter.branches",
          "group": "navigation@1"
        },
        {
          "command": "git-graph-alter.branches.showRemoteBranches",
          "when": "view == git-graph-alter.branches && !git-graph-alter.branchView.showingRemote",
          "group": "navigation@2"
        },
        {
          "command": "git-graph-alter.branches.hideRemoteBranches",
          "when": "view == git-graph-alter.branches && git-graph-alter.branchView.showingRemote",
          "group": "navigation@2"
        },
        {
          "command": "git-graph-alter.branches.collapseAll",
          "when": "view == git-graph-alter.branches",
          "group": "navigation@9"
        },
        {
          "command": "git-graph-alter.branches.search",
          "when": "view == git-graph-alter.branches",
          "group": "navigation@10"
        },
        {
          "command": "git-graph-alter.branches.showInactive",
          "when": "view == git-graph-alter.branches && !git-graph-alter.branchView.showingInactive",
          "group": "1_visibility@1"
        },
        {
          "command": "git-graph-alter.branches.hideInactive",
          "when": "view == git-graph-alter.branches && git-graph-alter.branchView.showingInactive",
          "group": "1_visibility@1"
        }
      ],
      "view/item/context": [
        {
          "command": "git-graph-alter.branches.checkout",
          "when": "view == git-graph-alter.branches && viewItem == branch-local && git-graph-alter.cmv.branch.checkout",
          "group": "1_action@1"
        },
        {
          "command": "git-graph-alter.branches.checkout",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.checkout",
          "group": "1_action@1"
        },
        {
          "command": "git-graph-alter.branches.rename",
          "when": "view == git-graph-alter.branches && viewItem =~ /^branch-(local|current)$/ && git-graph-alter.cmv.branch.rename",
          "group": "1_action@2"
        },
        {
          "command": "git-graph-alter.branches.merge",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.merge",
          "group": "1_action@2"
        },
        {
          "command": "git-graph-alter.branches.push",
          "when": "view == git-graph-alter.branches && viewItem =~ /^branch-(local|current)$/ && git-graph-alter.cmv.branch.push",
          "group": "1_action@3"
        },
        {
          "command": "git-graph-alter.branches.createArchive",
          "when": "view == git-graph-alter.branches && viewItem =~ /^branch-(local|current)$/ && git-graph-alter.cmv.branch.createArchive",
          "group": "1_action@4"
        },
        {
          "command": "git-graph-alter.branches.delete",
          "when": "view == git-graph-alter.branches && viewItem == branch-local && git-graph-alter.cmv.branch.delete",
          "group": "2_modify@1"
        },
        {
          "command": "git-graph-alter.branches.merge",
          "when": "view == git-graph-alter.branches && viewItem == branch-local && git-graph-alter.cmv.branch.merge",
          "group": "2_modify@2"
        },
        {
          "command": "git-graph-alter.branches.rebase",
          "when": "view == git-graph-alter.branches && viewItem == branch-local && git-graph-alter.cmv.branch.rebase",
          "group": "2_modify@3"
        },
        {
          "command": "git-graph-alter.branches.fastForward",
          "when": "view == git-graph-alter.branches && viewItem == branch-local",
          "group": "2_modify@4"
        },
        {
          "command": "git-graph-alter.branches.pull",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.pull",
          "group": "2_modify@1"
        },
        {
          "command": "git-graph-alter.branches.fetchIntoLocal",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.fetch",
          "group": "2_modify@2"
        },
        {
          "command": "git-graph-alter.branches.deleteRemote",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.delete",
          "group": "2_modify@3"
        },
        {
          "command": "git-graph-alter.branches.createPullRequest",
          "when": "view == git-graph-alter.branches && viewItem =~ /^branch-(local|current|remote)$/",
          "group": "3_share@1"
        },
        {
          "command": "git-graph-alter.branches.copyName",
          "when": "view == git-graph-alter.branches && viewItem =~ /^branch-(local|current)$/ && git-graph-alter.cmv.branch.copyName",
          "group": "4_copy@1"
        },
        {
          "command": "git-graph-alter.branches.copyName",
          "when": "view == git-graph-alter.branches && viewItem == branch-remote && git-graph-alter.cmv.remoteBranch.copyName",
          "group": "4_copy@1"
        }
      ],
      "commandPalette": [
        {
          "command": "git-graph-alter.branches.showRemoteBranches",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.hideRemoteBranches",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.showInactive",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.hideInactive",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.checkout",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.merge",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.rename",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.delete",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.copyName",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.rebase",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.fastForward",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.push",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.createArchive",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.createPullRequest",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.pull",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.fetchIntoLocal",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.deleteRemote",
          "when": "false"
        },
        {
          "command": "git-graph-alter.branches.collapseAll",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "%config.title%",
      "properties": {
        "git-graph-alter.detailsPanel.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoCenterCommitDetailsView%"
        },
        "git-graph-alter.detailsPanel.position": {
          "type": "string",
          "enum": [
            "Inline",
            "Docked to Bottom"
          ],
          "default": "Inline",
          "description": "%config.commitDetailsView.location%"
        },
        "git-graph-alter.refLabels.alignment": {
          "type": "string",
          "enum": [
            "Normal",
            "Branches (on the left) & Tags (on the right)",
            "Branches (aligned to the graph) & Tags (on the right)"
          ],
          "default": "Normal",
          "description": "%config.referenceLabels.alignment%"
        },
        "git-graph-alter.refLabels.combineLocalAndRemote": {
          "type": "boolean",
          "default": true,
          "description": "%config.referenceLabels.combineLocalAndRemoteBranchLabels%"
        },
        "git-graph-alter.dialogDefaults.addTagType": {
          "type": "string",
          "enum": [
            "annotated",
            "lightweight"
          ],
          "default": "annotated",
          "description": "%config.dialog.addTag.type%"
        },
        "git-graph-alter.dialogDefaults.cherryPickNoCommit": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.cherryPick.noCommit%"
        },
        "git-graph-alter.dialogDefaults.createBranchCheckOut": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.createBranch.checkOut%"
        },
        "git-graph-alter.dialogDefaults.mergeNoFastForward": {
          "type": "boolean",
          "default": true,
          "description": "%config.dialog.merge.noFastForward%"
        },
        "git-graph-alter.dialogDefaults.mergeSquash": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.merge.squash%"
        },
        "git-graph-alter.dialogDefaults.mergeSquashMessageFormat": {
          "type": "string",
          "enum": [
            "Default",
            "Git SQUASH_MSG"
          ],
          "enumDescriptions": [
            "%config.dialog.merge.squashMessageFormat.default%",
            "%config.dialog.merge.squashMessageFormat.gitSquashMsg%"
          ],
          "default": "Default",
          "description": "%config.dialog.merge.squashMessageFormat%"
        },
        "git-graph-alter.dialogDefaults.resetMode": {
          "type": "string",
          "enum": [
            "soft",
            "mixed",
            "hard"
          ],
          "default": "mixed",
          "description": "%config.dialog.resetCurrentBranch.mode%"
        },
        "git-graph-alter.dialogDefaults.deleteBranchForce": {
          "type": "boolean",
          "default": false,
          "description": "%config.dialog.deleteBranch.forceDelete%"
        },
        "git-graph-alter.history.showSignatures": {
          "type": "boolean",
          "default": false,
          "description": "%config.commits.showSignatureStatus%"
        },
        "git-graph-alter.contextMenuActions": {
          "type": "object",
          "description": "%config.contextMenuActionsVisibility%",
          "properties": {
            "commit": {
              "type": "object",
              "properties": {
                "addTag": {
                  "type": "boolean"
                },
                "createBranch": {
                  "type": "boolean"
                },
                "checkout": {
                  "type": "boolean"
                },
                "cherrypick": {
                  "type": "boolean"
                },
                "revert": {
                  "type": "boolean"
                },
                "merge": {
                  "type": "boolean"
                },
                "reset": {
                  "type": "boolean"
                },
                "rebase": {
                  "type": "boolean"
                },
                "drop": {
                  "type": "boolean"
                },
                "copyHash": {
                  "type": "boolean"
                },
                "copySubject": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "branch": {
              "type": "object",
              "properties": {
                "checkout": {
                  "type": "boolean"
                },
                "rename": {
                  "type": "boolean"
                },
                "push": {
                  "type": "boolean"
                },
                "createArchive": {
                  "type": "boolean"
                },
                "delete": {
                  "type": "boolean"
                },
                "merge": {
                  "type": "boolean"
                },
                "rebase": {
                  "type": "boolean"
                },
                "copyName": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "remoteBranch": {
              "type": "object",
              "properties": {
                "checkout": {
                  "type": "boolean"
                },
                "merge": {
                  "type": "boolean"
                },
                "pull": {
                  "type": "boolean"
                },
                "fetch": {
                  "type": "boolean"
                },
                "delete": {
                  "type": "boolean"
                },
                "copyName": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "tag": {
              "type": "object",
              "properties": {
                "viewDetails": {
                  "type": "boolean"
                },
                "delete": {
                  "type": "boolean"
                },
                "push": {
                  "type": "boolean"
                },
                "createArchive": {
                  "type": "boolean"
                },
                "copyName": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "stash": {
              "type": "object",
              "properties": {
                "apply": {
                  "type": "boolean"
                },
                "pop": {
                  "type": "boolean"
                },
                "drop": {
                  "type": "boolean"
                },
                "copyName": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "uncommittedChanges": {
              "type": "object",
              "properties": {
                "openSourceControlView": {
                  "type": "boolean"
                },
                "reset": {
                  "type": "boolean"
                },
                "clean": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "commitDetailsViewFile": {
              "type": "object",
              "properties": {
                "viewDiff": {
                  "type": "boolean"
                },
                "viewFileAtThisRevision": {
                  "type": "boolean"
                },
                "viewDiffWithWorkingFile": {
                  "type": "boolean"
                },
                "openFile": {
                  "type": "boolean"
                },
